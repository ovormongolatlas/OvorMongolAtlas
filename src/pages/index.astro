---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<h1>Övör Mongol Atlas</h1>
		<p class="tagline">An interactive historical atlas of Inner Mongolia (Övör Mongol), from the late Qing dynasty through the early People's Republic of China.</p>
		<p>
			Entries center on the Inner Mongolian autonomy movement of the 1930s and the Japanese-sponsored Mengjiang regime, and are built from scholarly and archival sources — academic monographs, journal articles, contemporary press, and firsthand accounts. Where sources disagree, this atlas records the disagreement rather than picking a side. Start with the <a href="/entries">Entries</a> index, or explore the <a href="/map">Timeline Map</a>.
		</p>
	</main>
</Layout>

<style>
	main {
		max-width: 60ch;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		font-family: system-ui, sans-serif;
	}

	h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	p {
		font-size: 1.1rem;
		color: #444;
	}

	.tagline {
		font-size: 1.2rem;
		color: #222;
	}
</style>
