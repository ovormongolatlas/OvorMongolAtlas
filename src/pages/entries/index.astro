---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { formatYearRange } from '../../lib/dates';

const allEntries = await getCollection('entries');

const typeOrder = ['person', 'place', 'group', 'battle', 'state'] as const;
const typeLabels: Record<(typeof typeOrder)[number], string> = {
	person: 'People',
	place: 'Places',
	group: 'Groups',
	battle: 'Battles',
	state: 'States',
};

type Entry = (typeof allEntries)[number];

function childrenOf(entry: Entry): Entry[] {
	return allEntries
		.filter((e) => e.data.partOf === entry.id)
		.sort((a, b) => a.data.startYear - b.data.startYear);
}

const groups = typeOrder
	.map((type) => ({
		type,
		label: typeLabels[type],
		// Entries that are a partOf another entry (e.g. Mengjiang's successive
		// governments) are nested under their parent below, not listed as flat peers.
		items: allEntries
			.filter((entry) => entry.data.type === type && !entry.data.partOf)
			.sort((a, b) => a.data.startYear - b.data.startYear),
	}))
	.filter((group) => group.items.length > 0);
---

<Layout>
	<main>
		<h1>Entries</h1>
		<div class="search">
			<input type="search" id="search-input" placeholder="Search entries by title or summary…" aria-label="Search entries" />
			<ul id="search-results"></ul>
		</div>
		{groups.map((group) => (
			<section>
				<h2>{group.label}</h2>
				<ul>
					{group.items.map((entry) => {
						const children = childrenOf(entry);
						return (
							<li>
								<a href={`/entry/${entry.id}`}>{entry.data.title}</a>
								<span class="years"> ({formatYearRange(entry.data.startYear, entry.data.endYear, entry.data.yearType)})</span>
								{children.length > 0 && (
									<>
										<p class="substages-note">Successive stages of {entry.data.title}:</p>
										<ul class="substages">
											{children.map((child) => (
												<li>
													<a href={`/entry/${child.id}`}>{child.data.title}</a>
													<span class="years"> ({formatYearRange(child.data.startYear, child.data.endYear, child.data.yearType)})</span>
												</li>
											))}
										</ul>
									</>
								)}
							</li>
						);
					})}
				</ul>
			</section>
		))}
	</main>
</Layout>

<script>
	import Fuse from 'fuse.js';

	type IndexEntry = { id: string; title: string; type: string; summary: string };

	const input = document.getElementById('search-input') as HTMLInputElement;
	const results = document.getElementById('search-results') as HTMLUListElement;

	if (location.hash === '#search-input') {
		input.focus();
	}

	const response = await fetch('/search-index.json');
	const entries: IndexEntry[] = await response.json();

	const fuse = new Fuse(entries, {
		keys: ['title', 'summary'],
		threshold: 0.35,
	});

	input.addEventListener('input', () => {
		const query = input.value.trim();
		results.innerHTML = '';

		if (!query) return;

		const matches = fuse.search(query).slice(0, 8);
		for (const { item } of matches) {
			const li = document.createElement('li');
			const a = document.createElement('a');
			a.href = `/entry/${item.id}`;
			a.textContent = item.title;
			li.appendChild(a);
			const type = document.createElement('span');
			type.className = 'years';
			type.textContent = ` (${item.type})`;
			li.appendChild(type);
			results.appendChild(li);
		}

		if (matches.length === 0) {
			const li = document.createElement('li');
			li.textContent = 'No matches.';
			li.className = 'years';
			results.appendChild(li);
		}
	});
</script>

<style>
	main {
		max-width: 60ch;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		font-family: system-ui, sans-serif;
	}

	h1 {
		font-size: 2rem;
	}

	h2 {
		font-size: 1.25rem;
		margin-top: 2rem;
	}

	ul {
		padding-left: 1.25rem;
	}

	.years {
		color: #777;
	}

	.substages-note {
		margin: 0.4rem 0 0.2rem;
		font-size: 0.9rem;
		color: #777;
	}

	.substages {
		padding-left: 1.25rem;
		margin-top: 0;
	}

	.search {
		margin-top: 1.5rem;
	}

	.search input {
		width: 100%;
		padding: 0.6rem 0.8rem;
		font-size: 1rem;
		border: 1px solid #ccc;
		border-radius: 6px;
		box-sizing: border-box;
	}

	.search ul {
		padding-left: 0;
		list-style: none;
		margin-top: 0.5rem;
	}

	.search li {
		padding: 0.25rem 0;
	}
</style>
